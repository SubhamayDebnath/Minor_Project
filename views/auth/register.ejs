<div class="auth-container">
    <div class="container">
        <div class="row">
            <div class="col-12 col-md-8 col-lg-5 mx-auto">
                <div class="card p-4 my-5">
                    <h1 class="fs-5 text-center mb-3">Sign in to your Account</h1>
                    <!-- <div class="alert alert-danger p-3 alert-dismissible fade show" role="alert">
                        <span>Please enter valid email/password</span>
                         <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                     </div>
                     <div class="alert alert-success p-3 alert-dismissible fade show" role="alert">
                         <span>Please enter valid email/password</span>
                          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                      </div> -->
                    <form action="">
                        <div class="form-group mb-3">
                            <label for="username" class="form-label">Username</label>
                            <input type="text" name="username" id="username" class="form-control" placeholder="Enter your username" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="phone" class="form-label">Phone</label>
                            <input type="text" name="phone" id="phone" minlength="10" class="form-control" placeholder="Enter your phone number" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" name="email" id="email" class="form-control" placeholder="Enter your email" required>
                        </div>
                        <div class="form-group mb-3">
                            <label for="pasword" class="form-label">Password</label>
                            <input type="password" name="password" id="password" class="form-control" placeholder="Enter your password" required>
                        </div>
                        <div class="mb-3">
                            <span class="form-label">Location</span>
                            <div class="input-group mt-2">
                                <button type="button" class="btn btn-primary" onclick="getUserLocation()">Get your location</button>
                            </div>
                            <div class="input-group mt-2">
                                <input type="hidden" id="latitude" name="latitude" required>
                                <input type="hidden" id="longitude" name="longitude" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Register</button>
                    </form>
                    <div class="mt-3">
                        <p class="mb-0">Have a account? <a href="/login">Login now</a></p>
                        <a href="/">Back to home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    function getUserLocation() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function(position) {
                    let latitude = position.coords.latitude;
                    let longitude = position.coords.longitude;
                    let location = "Latitude: " + latitude + ", Longitude: " + longitude;
                    document.getElementById("latitude").value = latitude;
                    document.getElementById("longitude").value = longitude;
                    document.getElementById("location").value = location;
                }, function(error) {
                    alert("Geolocation is not available or denied.");
                });
            } else {
                alert("Geolocation is not supported by this browser.");
            }
        }
</script>